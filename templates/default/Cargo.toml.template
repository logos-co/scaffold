[package]
name = "{{crate_name}}"
version = "0.1.0"
edition = "2024"
license = { workspace = true }

[workspace.package]
license = "MIT or Apache-2.0"

[workspace]
resolver = "3"
members = [
  ".",
  "methods",
  "methods/guest",
]

[workspace.lints.rust]
unsafe_code = "warn"

[workspace.dependencies]
nssa = { git = "https://github.com/logos-blockchain/logos-execution-zone.git", rev = "{{lez_pin}}" }
nssa_core = { git = "https://github.com/logos-blockchain/logos-execution-zone.git", rev = "{{lez_pin}}" }
wallet = { git = "https://github.com/logos-blockchain/logos-execution-zone.git", rev = "{{lez_pin}}" }
common = { git = "https://github.com/logos-blockchain/logos-execution-zone.git", rev = "{{lez_pin}}" }
sequencer_service_rpc = { git = "https://github.com/logos-blockchain/logos-execution-zone.git", rev = "{{lez_pin}}", default-features = false, features = ["client"] }

anyhow = "1.0.98"
risc0-zkvm = { version = "3.0.5", features = ["std"] }
risc0-build = "3.0.5"

hex = "0.4.3"
bytemuck = "1.24.0"
tokio = { version = "1.28.2", features = ["macros", "net", "rt-multi-thread", "sync", "fs"] }
clap = { version = "4.5.42", features = ["derive", "env"] }

[dependencies]
nssa.workspace = true
nssa_core.workspace = true
wallet.workspace = true
common.workspace = true
sequencer_service_rpc.workspace = true
example_program_deployment_methods = { path = "methods" }

anyhow.workspace = true
clap.workspace = true
hex.workspace = true
tokio = { workspace = true, features = ["macros"] }
